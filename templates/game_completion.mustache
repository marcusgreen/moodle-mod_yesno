{{!
    @template mod_yesno/game_completion

    Template for the game completion screen shown after a win or loss.

    Example context (json):
    {
        "is_win": true,
        "is_loss": false,
        "game_won_title": "You won!",
        "game_won_message": "You guessed correctly!",
        "game_lost_title": "",
        "game_lost_message": "",
        "show_score": true,
        "score_label": "Final score:",
        "final_score": 85,
        "reveal_secret": "banana",
        "reveal_secret_label": "The secret was:",
        "try_another_url": "http://example.com/mod/yesno/view.php?tryanother=1",
        "try_another_text": "Try Another Secret",
        "finish_session_url": "http://example.com/mod/yesno/view.php?finish=1",
        "finish_session_text": "Finish session"
    }
}}
{{#is_win}}
<div class="yesno-game-completion yesno-game-won" id="yesno-win-celebration">
    <div class="yesno-celebration-alert">
        <div class="yesno-celebration-stars" aria-hidden="true">
            <span class="yesno-star">&#9733;</span>
            <span class="yesno-star">&#9733;</span>
            <span class="yesno-star">&#9733;</span>
            <span class="yesno-star">&#9733;</span>
            <span class="yesno-star">&#9733;</span>
        </div>
        <h3><i class="fa fa-trophy yesno-trophy-icon"></i> {{game_won_title}}</h3>
        <p>{{game_won_message}}</p>
        {{#show_score}}
        <p class="yesno-final-score"><strong>{{score_label}}</strong> {{final_score}}</p>
        {{/show_score}}
    </div>
</div>
{{/is_win}}
{{#is_loss}}
<div class="yesno-game-completion yesno-game-lost">
    <div class="alert alert-info">
        <h3><i class="fa fa-info-circle"></i> {{game_lost_title}}</h3>
        <p>{{game_lost_message}}</p>
        {{#reveal_secret}}
        <p class="yesno-reveal-secret"><strong>{{reveal_secret_label}}</strong> {{reveal_secret}}</p>
        {{/reveal_secret}}
    </div>
</div>
{{/is_loss}}

<div class="yesno-completion-actions">
    <a href="{{try_another_url}}" class="btn btn-primary">
        <i class="fa fa-refresh"></i> {{try_another_text}}
    </a>
    <a href="{{finish_session_url}}" class="btn btn-secondary">
        <i class="fa fa-sign-out"></i> {{finish_session_text}}
    </a>
</div>
