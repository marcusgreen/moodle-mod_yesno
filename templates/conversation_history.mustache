{{!
    @template mod_yesno/conversation_history

    Conversation history template for yesno module
    Renders the history of questions and AI responses

    Example context (json):
    {
        "has_history": true,
        "conversation_history_title": "Conversation History",
        "history_items": [
            {
                "your_question_label": "Your Question",
                "question": "Is it an animal?",
                "ai_response_label": "AI Response",
                "response": "Yes",
                "timestamp": "2025-01-13 10:30:00"
            }
        ]
    }
}}
{{#has_history}}
<div class="yesno-conversation-history">
    <h4>{{conversation_history_title}}</h4>
    {{#history_items}}
    <div class="history-item {{#is_correct}}history-item-correct{{/is_correct}}{{^is_correct}}history-item-incorrect{{/is_correct}}">
        <div class="history-response-indicator">
            <span class="feedback-icon {{#is_correct}}feedback-icon-correct{{/is_correct}}{{^is_correct}}feedback-icon-incorrect{{/is_correct}}">
                {{feedback_icon}}
            </span>
            <span class="feedback-label {{#is_correct}}feedback-correct{{/is_correct}}{{^is_correct}}feedback-incorrect{{/is_correct}}">
                {{feedback_label}}
            </span>
        </div>
        <div class="history-question-block">
            <div class="history-question-label">{{your_question_label}}</div>
            <div class="history-question-text">{{{question}}}</div>
        </div>
        <div class="history-response-block">
            <div class="history-response-label">{{ai_response_label}}</div>
            <div class="history-response-text">{{{response}}}</div>
        </div>
        <div class="history-timestamp"><small>{{timestamp}}</small></div>
    </div>
    {{/history_items}}
</div>
{{/has_history}}